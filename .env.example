# ── Groq AI ──────────────────────────────────────────────────────────────────
# Required. Get your key at https://console.groq.com
VITE_GROQ_API_KEY="your_groq_api_key_here"

# ── Hiro / Stacks API ────────────────────────────────────────────────────────
# Optional but strongly recommended to avoid 429 rate-limit errors.
# Free tier: 30 req/min. Get a key at https://platform.hiro.so
VITE_HIRO_API_KEY="your_hiro_api_key_here"

# ── Firebase ─────────────────────────────────────────────────────────────────
# Paste the full JSON object from your Firebase project settings → Web app → Config
VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
