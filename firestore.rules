rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // DEV MODE — open read/write while Firebase Auth is removed.
    // Wallet address (SP...) is used as the document path key.
    // TODO: Replace with Stacks signature verification middleware
    //       once the backend can validate signed Stacks messages.
    // ─────────────────────────────────────────────────────────────

    // User profile document: /users/{walletAddress}
    match /users/{walletAddress} {
      allow read, write: if true;

      // Transactions subcollection: /users/{walletAddress}/transactions/{txId}
      match /transactions/{txId} {
        allow read, write: if true;
      }

      // Contacts subcollection: /users/{walletAddress}/contacts/{contactId}
      match /contacts/{contactId} {
        allow read, write: if true;
      }
    }
  }
}
